# HAMH - Hermes Agent Management Hub
# Environment Variables

# Required: API key for CLI / dashboard / worker authentication
# Generate a strong random key: openssl rand -hex 32
API_KEY=your_random_api_key_here

# Optional: Miah VPS host (for reference, not used in polling mode)
MIAH_HOST=

# Server port (Railway sets this automatically)
PORT=3000
