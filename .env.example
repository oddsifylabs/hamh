# HAMH - Hermes Agent Management Hub
# Environment Variables

# Required for Telegram notifications to Jesse
TELEGRAM_BOT_TOKEN=your_bot_token_here
JESSE_CHAT_ID=your_telegram_chat_id_here

# Optional: Miah VPS host (for reference, not used in polling mode)
MIAH_HOST=

# Server port (Railway sets this automatically)
PORT=3000