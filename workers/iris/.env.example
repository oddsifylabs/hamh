# Iris Hermes Worker — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to Git.

# HWMH Hub endpoint
HWMH_BASE_URL=https://hwmh.oddsifylabs.com

# Polling interval (ms)
POLL_INTERVAL_MS=15000

# Optional: API key if hub requires auth on worker endpoints
# HWMH_API_KEY=

# Optional: External service credentials
# KIMI_API_KEY=
# EMAIL_SMTP_HOST=
# EMAIL_SMTP_USER=
# EMAIL_SMTP_PASS=
