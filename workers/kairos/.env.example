# Kairos Hermes Worker — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to Git.

# HWMH Hub endpoint
HWMH_BASE_URL=https://hwmh.oddsifylabs.com

# Polling interval (ms)
POLL_INTERVAL_MS=15000

# Optional: API key if hub requires auth on worker endpoints
# HWMH_API_KEY=

# Sales / CRM credentials
# SALESFORCE_CLIENT_ID=
# SALESFORCE_CLIENT_SECRET=
# HUBSPOT_API_KEY=
