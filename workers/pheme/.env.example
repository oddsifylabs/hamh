# Pheme Hermes Worker — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to Git.

# HWMH Hub endpoint
HWMH_BASE_URL=https://hwmh.oddsifylabs.com

# Polling interval (ms)
POLL_INTERVAL_MS=15000

# Optional: API key if hub requires auth on worker endpoints
# HWMH_API_KEY=

# Social platform credentials
# X_API_KEY=
# X_API_SECRET=
# X_ACCESS_TOKEN=
# X_ACCESS_SECRET=
